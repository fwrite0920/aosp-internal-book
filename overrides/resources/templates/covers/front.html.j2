<div class="mkdocs-exporter-front-cover" data-decompose="true">
  <style>
    .mkdocs-exporter-front-cover {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      height: 100vh;
      background: linear-gradient(135deg, #1b5e20 0%, #2e7d32 40%, #43a047 100%);
      color: white;
      text-align: center;
      font-family: 'Roboto', sans-serif;
      page-break-after: always;
    }
    .mkdocs-exporter-front-cover h1 {
      font-size: 3em;
      margin: 0.3em 0;
      font-weight: 700;
      letter-spacing: -0.02em;
    }
    .mkdocs-exporter-front-cover h2 {
      font-size: 1.5em;
      font-weight: 300;
      margin: 0;
      opacity: 0.9;
    }
    .mkdocs-exporter-front-cover .divider {
      width: 120px;
      height: 3px;
      background: rgba(255,255,255,0.5);
      margin: 2em 0;
      border: none;
    }
    .mkdocs-exporter-front-cover .meta {
      font-size: 0.95em;
      opacity: 0.7;
      margin-top: 1em;
    }
  </style>

  <h1>{{ config.site_name }}</h1>
  <hr class="divider">
  <h2>{{ config.site_description }}</h2>
  <p class="meta">64 Chapters &bull; ~1,500 Diagrams &bull; Source-Referenced</p>
</div>
